<Window x:Class="RoundedTB.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RoundedTB"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        xmlns:wpfui="clr-namespace:WPFUI.Controls;assembly=WPFUI"
        mc:Ignorable="d"
        Style="{StaticResource UiWindow}"
        Title="RoundedTB Enhanced" Height="750" Width="520"
        Background="#20808080"
        d:Background="DarkGray"
        Visibility = "Visible"
        Opacity="0.001"
        d:Opacity="1"
        ResizeMode="NoResize"
        >
    <!--169, 393-->
    <Grid x:Name="MainGrid" Margin="0,0,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MinHeight="30" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <wpfui:TitleBar x:Name="mainTitleBar" Grid.Row="0" UseNotifyIcon="True" NotifyIconImage="pack://application:,,,/res/traydark.ico" NotifyIconTooltip="RoundedTB Enhanced" Margin="0,0,0,0" Title="RoundedTB Enhanced" Icon="pack://application:,,,/RoundedTBCanary.ico" Height="51" ShowMaximize="False">
            <wpfui:TitleBar.NotifyIconMenu>
                <ContextMenu MouseEnter="ContextMenu_MouseEnter">
                    <CheckBox x:Name ="StartupCheckBox" Content="Run at startup" Click="Startup_Clicked"/>
                    <MenuItem x:Name="DebugMenuItem" Header="Debug" Visibility ="Hidden" Click="DebugMenuItem_Click" Height="0"/>
                    <MenuItem x:Name ="ShowMenuItem" Header="Show RoundedTB" Click="ShowMenuItem_Click"/>
                    <MenuItem x:Name ="CloseMenuItem" Header="Close RoundedTB" Click="CloseMenuItem_Click"/>
                </ContextMenu>
            </wpfui:TitleBar.NotifyIconMenu>
        </wpfui:TitleBar>

        <!-- Row 1: Top Banner Image (No gaps) -->
        <Image Grid.Row="1" Source="res\roundedTB.png" Width="520" Height="276" Stretch="UniformToFill" Margin="0,0,0,15"/>

        <!-- Row 2: Settings Controls (Inside a rounded card) -->
        <Border Grid.Row="2" CornerRadius="8" Background="#0AFFFFFF" BorderBrush="#1CFFFFFF" BorderThickness="1" Margin="15,0,15,15" Padding="15">
            <StackPanel Margin="0">


                <!-- Taskbar diagram (Hidden/Collapsed) -->
                <Grid x:Name="tbDiagramGrid" Margin="0,0,0,0" Height="0" Width="0" Visibility="Collapsed">
                    <Rectangle Stroke="#30242424" Fill="#20808080" RadiusX="5" RadiusY="5"/>
                    <wpfui:Button x:Name="taskbarRectStandIn" Margin="126,0,126,5" VerticalAlignment="Bottom" Click="taskbarRectStandIn_Click" Appearance="Primary" Height="32"></wpfui:Button>
                    <wpfui:Button x:Name="trayRectStandIn" Margin="415,0,5,5" Click="trayRectStandIn_Click" VerticalAlignment="Bottom" Height="32" Appearance="Secondary" Padding="0">📅</wpfui:Button>
                    <wpfui:Button x:Name="widgetsRectStandIn" Margin="5,0,415,5" Click="widgetsRectStandIn_Click" VerticalAlignment="Bottom" Height="32" Appearance="Secondary" Padding="0">📰</wpfui:Button>
                    <wpfui:Button x:Name="clockRectStandIn" Margin="415,0,5,60" Click="clockRectStandIn_Click" VerticalAlignment="Bottom" Height="32" Appearance="Secondary" VerticalContentAlignment="Center" Padding="0">🕑</wpfui:Button>

                    <Label Content="RoundedTB" HorizontalAlignment="Center" Margin="0,59,0,108" FontFamily="Segoe UI Variable Display" FontWeight="SemiBold" FontSize="60" Opacity="0.75"/>
                    <Label Content="To begin, select a taskbar segment below." HorizontalAlignment="Center" Margin="0,138,0,75" FontFamily="Segoe UI Variable Display" FontWeight="SemiBold" FontSize="20" Opacity="0.75"/>
                </Grid>

                <!-- Hidden inputs/buttons that code behind references -->
                <CheckBox x:Name="centredCheckBox" Content="Centred taskbar?" Visibility="Collapsed"/>
                <Button x:Name="splitHelpButton" Click="splitHelpButton_Click" Visibility="Collapsed"/>

                <!-- Two Column layout for settings -->
                <!-- Full Width Settings Layout -->
                <StackPanel Margin="0,0,0,15">
                    <!-- Corner Radius Grid (Full Width) -->
                    <Grid Height="55" Margin="0,0,0,15">
                        <Label x:Name="cornerRadiusLabel" Content="Corner radius" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                        <TextBox x:Name="cornerRadiusInput" TextWrapping="NoWrap" Text="" VerticalAlignment="Top" HorizontalAlignment="Right" Width="100" Margin="0,19,0,0" LostFocus="cornerRadiusInput_LostFocus"/>
                        <Slider x:Name="cornerRadiusSlider" Height="10" VerticalAlignment="Top" HorizontalAlignment="Stretch" Margin="0,25,120,0" LargeChange="0" SmallChange="1" Focusable="False" Maximum="48" Orientation="Horizontal" Thumb.DragCompleted="cornerRadiusSlider_DragCompleted" ValueChanged="cornerRadiusSlider_ValueChanged"/>
                    </Grid>

                    <!-- Margins Grid (Full Width Side-by-Side) -->
                    <Grid Height="60" Margin="0,0,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <!-- Top Margin -->
                        <StackPanel Grid.Column="0" Margin="0,0,5,0">
                            <Label x:Name="mTopLabel" Content="Top Margin" HorizontalAlignment="Center"/>
                            <TextBox x:Name="mTopInput" TextWrapping="NoWrap" HorizontalContentAlignment="Center" LostFocus="mTopInput_LostFocus"/>
                        </StackPanel>
                        <!-- Bottom Margin -->
                        <StackPanel Grid.Column="1" Margin="5,0,5,0">
                            <Label x:Name="mBottomLabel" Content="Bottom Margin" HorizontalAlignment="Center"/>
                            <TextBox x:Name="mBottomInput" TextWrapping="NoWrap" HorizontalContentAlignment="Center" LostFocus="mBottomInput_LostFocus"/>
                        </StackPanel>
                        <!-- Left Margin -->
                        <StackPanel Grid.Column="2" Margin="5,0,5,0">
                            <Label x:Name="mLeftLabel" Content="Left Margin" HorizontalAlignment="Center"/>
                            <TextBox x:Name="mLeftInput" TextWrapping="NoWrap" HorizontalContentAlignment="Center" LostFocus="mLeftInput_LostFocus"/>
                        </StackPanel>
                        <!-- Right Margin -->
                        <StackPanel Grid.Column="3" Margin="5,0,0,0">
                            <Label x:Name="mRightLabel" Content="Right Margin" HorizontalAlignment="Center"/>
                            <TextBox x:Name="mRightInput" TextWrapping="NoWrap" HorizontalContentAlignment="Center" LostFocus="mRightInput_LostFocus"/>
                        </StackPanel>
                    </Grid>

                    <!-- Hidden/Collapsed elements to satisfy code-behind references -->
                    <Grid x:Name="hiddenOptionsGrid" Visibility="Collapsed" Height="0" Width="0">
                        <CheckBox x:Name="showTrayCheckBox"/>
                        <CheckBox x:Name="showWidgetsCheckBox"/>
                        <CheckBox x:Name="showClockCheckBox"/>
                        <Label x:Name="widgetWidthLabel"/>
                        <TextBox x:Name="widgetWidthInput"/>
                        <Label x:Name="clockWidthLabel"/>
                        <TextBox x:Name="clockWidthInput"/>
                    </Grid>
                </StackPanel>

                <!-- Divider line -->
                <Rectangle HorizontalAlignment="Center" Margin="0,0,0,15" Stroke="#4C909090" Width="480" RadiusX="1" RadiusY="1.5" Height="1"/>

                <!-- Checkboxes Grid -->
                <Grid Margin="0,0,0,15" Height="120">
                    <CheckBox x:Name="dynamicCheckBox" Content="Dynamic mode" Margin="0,0,0,0" VerticalAlignment="Top" Checked="dynamicCheckBox_Checked" Unchecked="dynamicCheckBox_Unchecked" HorizontalAlignment="Left" />
                    <CheckBox x:Name="showSegmentsOnHoverCheckBox" Content="Show system tray on hover" Margin="0,30,0,0" VerticalAlignment="Top" Checked="showSegmentsOnHoverCheckBox_Checked" Unchecked="showSegmentsOnHoverCheckBox_Unchecked" HorizontalAlignment="Left" />
                    <CheckBox x:Name="fillMaximisedCheckBox" Content="When the taskbar is full, restore the taskbar" Margin="0,60,0,0" Checked="fillMaximisedCheckBox_Checked" Unchecked="fillMaximisedCheckBox_Unchecked" VerticalAlignment="Top" HorizontalAlignment="Left" />
                    <CheckBox x:Name="compositionFixCheckBox" Content="Improve compatibility with TranslucentTB" Margin="0,90,0,0" VerticalAlignment="Top" IsChecked="False" Checked="compositionFixCheckBox_Checked" HorizontalAlignment="Left" />
                    <CheckBox x:Name="fillAltTabCheckBox" Visibility="Collapsed" Content="When alt+tab or win+tab is pressed, restore the taskbar" Margin="0,120,0,0" VerticalAlignment="Top" HorizontalAlignment="Left" />
                </Grid>

                <!-- Buttons bottom -->
                <Grid Margin="0,0,0,0">
                    <wpfui:Button x:Name="applyButton" Content="Apply" Click="ApplyButton_Click" FontWeight="Normal" HorizontalAlignment="Stretch" Height="32"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>
